# InfraFlow Environment Variables

# LLM API Configuration (Optional - for AI-powered parsing)
# Choose one: Claude (Anthropic) or OpenAI

# Claude API (Recommended)
# Server-side only - NOT exposed to client
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API (Alternative)
# Server-side only - NOT exposed to client
OPENAI_API_KEY=your-openai-api-key-here

# Note: At least one API key is required for LLM-powered parsing
# Without API keys, the app uses built-in template matching
#
# SECURITY: API keys are stored server-side only and accessed via /api/llm
# They are NEVER exposed to the client browser

# Redis (Upstash) Configuration — Required for production rate limiting
# Without these, the rate limiter uses an in-memory store (resets on cold start)
# Get credentials from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url-here
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token-here

# LLM Model Configuration (Optional)
# Model to use for diagram modification (default: claude-sonnet-4-20250514)
# Available Sonnet models:
#   - claude-sonnet-4-20250514 (Sonnet 4, latest)
#   - claude-3-5-sonnet-20241022 (Sonnet 3.5)
#   - claude-3-sonnet-20240229 (Sonnet 3)
LLM_MODEL=claude-sonnet-4-20250514

# Maximum tokens for LLM response (default: 2048)
LLM_MAX_TOKENS=2048

# Timeout for LLM API calls in milliseconds (default: 30000)
LLM_TIMEOUT_MS=30000

# Maximum retry attempts for LLM API calls (default: 2)
LLM_MAX_RETRIES=2

# RAG Configuration (Optional — controls vector search behavior)
# Cache TTL for fetched external content in hours (default: 24)
RAG_CACHE_TTL_HOURS=24

# Timeout for external content fetching in milliseconds (default: 10000)
RAG_FETCH_TIMEOUT_MS=10000

# Number of top results to return from vector search (default: 10)
RAG_TOP_K=10

# Minimum similarity score for RAG results, 0.0-1.0 (default: 0.5)
RAG_MIN_SCORE=0.5

# Bundle Analysis
# Set to 'true' to generate webpack bundle analysis report on build.
# Usage: ANALYZE=true npm run build
# This opens an interactive treemap of the production bundle in your browser.
ANALYZE=false

# Demo Mode (로컬 개발용 — 인증 우회, DB 불필요)
# true로 설정하면 USER 권한으로 자동 로그인됨 (읽기 전용)
# NEXT_PUBLIC_DEMO_MODE=true

# Demo Admin Mode (통제된 환경에서만 사용 — demo mode에서 관리자 접근 허용)
# NEXT_PUBLIC_DEMO_MODE=true와 함께 설정해야 동작
# DEMO_ADMIN_ENABLED=true
